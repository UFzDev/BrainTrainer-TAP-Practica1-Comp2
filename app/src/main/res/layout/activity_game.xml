<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_void"
    tools:context=".GameActivity">

    <!-- Pantalla de Preparación -->
    <LinearLayout
        android:id="@+id/layoutPreparation"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="visible">

        <TextView
            android:id="@+id/tvPreparationCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3"
            android:textColor="@color/primary_purple"
            android:textSize="120sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¡PREPÁRATE!"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:letterSpacing="0.2" />
    </LinearLayout>

    <!-- Contenido del Juego -->
    <RelativeLayout
        android:id="@+id/layoutGameContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="24dp"
        android:visibility="gone">

        <!-- Barra Superior -->
        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true"
            android:text="00:60"
            android:textColor="@color/tertiary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true"
            android:text="Score: 0"
            android:textColor="@color/easy_green"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- Operación -->
        <TextView
            android:id="@+id/tvOperation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:fontFamily="sans-serif-black"
            android:text="25 + 14"
            android:textColor="@color/text_primary"
            android:textSize="64sp"
            android:textStyle="bold" />

        <!-- Respuestas -->
        <LinearLayout
            android:id="@+id/llOptionsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="16dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnOption1"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_margin="8dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/surface_card"
                    android:text="39"
                    android:textColor="@color/text_primary"
                    android:textSize="24sp"
                    app:cornerRadius="16dp" />

                <Button
                    android:id="@+id/btnOption2"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_margin="8dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/surface_card"
                    android:text="42"
                    android:textColor="@color/text_primary"
                    android:textSize="24sp"
                    app:cornerRadius="16dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnOption3"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_margin="8dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/surface_card"
                    android:text="28"
                    android:textColor="@color/text_primary"
                    android:textSize="24sp"
                    app:cornerRadius="16dp" />

                <Button
                    android:id="@+id/btnOption4"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_margin="8dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/surface_card"
                    android:text="35"
                    android:textColor="@color/text_primary"
                    android:textSize="24sp"
                    app:cornerRadius="16dp" />
            </LinearLayout>
        </LinearLayout>
    </RelativeLayout>

    <!--Pantalla Final -->
    <LinearLayout
        android:id="@+id/layoutResults"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background_void"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvFinalScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/title_final"
            android:textColor="@color/primary_purple"
            android:textSize="48sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp" />

        <Button
            android:id="@+id/btnPlayAgain"
            android:layout_width="250dp"
            android:layout_height="80dp"
            android:text="@string/restart_final"
            android:backgroundTint="@color/easy_green"
            android:textColor="@color/easy_green_dark"
            android:textSize="18sp"
            android:textStyle="bold"
            app:cornerRadius="20dp"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnGoMenu"
            android:layout_width="250dp"
            android:layout_height="80dp"
            android:text="@string/menu_final"
            android:backgroundTint="@color/surface_card"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            app:cornerRadius="20dp" />
    </LinearLayout>
</FrameLayout>