<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_void"
    tools:context=".GameActivity">

    <LinearLayout
        android:id="@+id/layoutPreparation"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="visible">

        <TextView
            android:id="@+id/tvPreparationCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3"
            android:textColor="@color/primary_purple"
            android:textSize="120sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¡PREPÁRATE!"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:letterSpacing="0.2" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutGameContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¡A JUGAR!"
            android:textColor="@color/easy_green"
            android:textSize="40sp"
            android:textStyle="bold" />

    </LinearLayout>

</FrameLayout>